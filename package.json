{
  "name": "style-loop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "pnpm codegen",
    "dev:webpack": "next dev --no-turbo",
    "dev:turbo": "next dev --turbo",
    "build": "cross-env NODE_ENV=production next build --no-lint",
    "start": "next start",
    "lint": "next lint",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "dev:with-types": "yarn codegen && next dev",
    "codegen:prod": "GRAPHQL_ENDPOINT=http://localhost:3000/api/graphql npm run codegen",
    "seed": "tsx scripts/seed.ts",
    "dev:seed": "tsx scripts/seed.ts && next dev"
  },
  "dependencies": {
    "@apollo/client": "^4.0.9",
